{$SITE_ADDRESS:http://localhost} {
  encode zstd gzip

  handle /api/* {
    reverse_proxy api:4000
  }

  handle /socket.io/* {
    reverse_proxy api:4000
  }

  handle {
    root * /srv
    try_files {path} /index.html
    file_server
  }

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy strict-origin-when-cross-origin
    -Server
  }
}
