{
  "name": "pairboard",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"npm run dev -w @pairboard/api\" \"npm run dev -w @pairboard/web\"",
    "build": "npm run build -w @pairboard/api && npm run build -w @pairboard/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "verify:scenarios": "node scripts/verify-scenarios.mjs",
    "db:generate": "dotenv -e .env -- prisma generate --schema apps/api/prisma/schema.prisma",
    "db:migrate": "dotenv -e .env -- prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "db:push": "dotenv -e .env -- prisma db push --schema apps/api/prisma/schema.prisma",
    "db:seed": "dotenv -e .env -- tsx apps/api/prisma/seed.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv-cli": "^8.0.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
